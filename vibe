#!/bin/bash

set -e

# Default modes
DEBUG=0
BUILD=0
DOWN=0
KEEP=0
VSCODE=0

# Parse flags
while getopts "BdDklv" opt; do
  case $opt in
    B) BUILD=1;;
    d) DOWN=1;;
    D) DEBUG=1;;
    k) KEEP=1;;
    l) LOCAL=1;;
    v) VSCODE=1;;
    *) echo "Usage: vibe [-B] [-d] [-D] [-k] [-l] [-v] [directory] [-- args...]"; exit 1;;
  esac
done
shift $((OPTIND - 1))

# Split positional args at -- separator
WORKTREE=""
WORKTREE_BRANCH=""
EXTRA_ARGS=()
if [[ "${1:-}" == "--" ]]; then
  # No directory arg, rest goes to tool
  shift
  EXTRA_ARGS=("$@")
  TARGET_DIR="$PWD"
elif [[ "${1:-}" == w:* ]]; then
  # Git worktree mode: create/reuse a worktree under .w/
  WORKTREE_BRANCH="${1#w:}"
  WORKTREE_BASE="$(git rev-parse --show-toplevel)/.w"
  WORKTREE_DIR="${WORKTREE_BASE}/${WORKTREE_BRANCH}"

  mkdir -p "$WORKTREE_BASE"
  if [[ ! -f "$WORKTREE_BASE/.gitignore" ]]; then
    echo '*' > "$WORKTREE_BASE/.gitignore"
  fi

  if [[ ! -d "$WORKTREE_DIR" ]]; then
    if git show-ref --verify --quiet "refs/heads/$WORKTREE_BRANCH"; then
      git worktree add "$WORKTREE_DIR" "$WORKTREE_BRANCH"
    else
      git worktree add -b "$WORKTREE_BRANCH" "$WORKTREE_DIR"
    fi
  fi

  TARGET_DIR="$(realpath "$WORKTREE_DIR")"
  WORKTREE="$WORKTREE_DIR"
  shift
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
else
  TARGET_DIR="$(realpath -- "${1:-$PWD}")"
  shift || true
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
fi
if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: '$TARGET_DIR' is not a directory" >&2
  exit 1
fi
export TARGET_DIR

# Ensure .vibe/ exists and mount it
if [[ -n "$WORKTREE" ]]; then
  VIBE_DIR="$(git rev-parse --show-toplevel)/.vibe"
else
  VIBE_DIR="${TARGET_DIR}/.vibe"
fi
mkdir -p "$VIBE_DIR"
if [[ ! -f "$VIBE_DIR/.gitignore" ]]; then
  echo '*' > "$VIBE_DIR/.gitignore"
fi
export VIBE_DIR

# Base docker arguments
DIR_HASH="$(echo -n "$TARGET_DIR" | md5sum | cut -c1-4)"
DIR_BASENAME="$(basename "$TARGET_DIR" | tr -cd "a-zA-Z0-9-" | tr " " "-" | tr "." "-" | tr "_" "-")"

# Make sure to use the base repo's name when using worktrees
if [[ -n "$WORKTREE" ]]; then
  REPO_BASENAME="$(basename "$(git rev-parse --show-toplevel)" | tr -cd "a-zA-Z0-9-" | tr " " "-" | tr "." "-" | tr "_" "-")"
  PROJECT_NAME="vibe-${REPO_BASENAME}-${DIR_BASENAME}-${DIR_HASH}"
else
  PROJECT_NAME="vibe-${DIR_BASENAME}-${DIR_HASH}"
fi

export PROJECT_NAME="${PROJECT_NAME,,}"
DOCKER_COMPOSE="$(cat <<'EOF'
services:
  claude:
    network_mode: bridge
    build:
      args:
        UID: ${UID:-1000}
        GID: ${GID:-1000}
        PROJECT_NAME: ${PROJECT_NAME}
        ENTRYPOINT: |
          #!/bin/bash

          # Export the SSH_AUTH_SOCK if it exists
          if [[ -S /tmp/ssh_auth_sock ]]; then
            export SSH_AUTH_SOCK=/tmp/ssh_auth_sock
          fi

          # Symlink the GnuPG socket to the correct directory if it exists
          if [[ -S /tmp/gnupg_sock ]]; then
            GNUPG_SOCK=$$(gpgconf --list-dir agent-socket)
            mkdir -m 700 -p "$$(dirname "$$GNUPG_SOCK")"
            ln -sf /tmp/gnupg_sock "$$GNUPG_SOCK"
          fi

          # Import host GPG public keys once per container start
          if [[ -n "$${GPG_PUBKEYS:-}" && ! -f /tmp/.gpg_keys_imported ]]; then
            gpgconf --kill keyboxd 2>/dev/null
            echo "$$GPG_PUBKEYS" | gpg --import 2>/dev/null ||:
            touch /tmp/.gpg_keys_imported
          fi

          if [[ -f /tmp/host_gitconfig ]]; then
            ln -sf /tmp/host_gitconfig "$$HOME/.gitconfig"
          fi

          if [[ -f /tmp/host_claude_json ]]; then
            ln -sf /tmp/host_claude_json "$$HOME/.claude.json"
          else
            if [[ ! -f "$$HOME/.claude/claude.json" ]]; then
              echo '{}' > "$$HOME/.claude/claude.json"
            fi
            ln -sf "$$HOME/.claude/claude.json" "$$HOME/.claude.json"
          fi

          # Set EDITOR to the code wrapper if VS Code FIFO is available
          if [[ -p /tmp/vscode_fifo ]]; then
            export EDITOR="code -w"
          fi

          # Auto-trust the workspace directory so Claude doesn't prompt
          node -e "
            var fs = require('fs'), f = process.env.HOME + '/.claude.json';
            var d = JSON.parse(fs.readFileSync(f, 'utf8'));
            var p = d.projects = d.projects || {}, dir = process.cwd();
            if (!p[dir] || !p[dir].hasTrustDialogAccepted) {
              p[dir] = Object.assign(p[dir] || {}, {hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true});
              fs.writeFileSync(f, JSON.stringify(d, null, 2));
            }
          " 2>/dev/null || true

          exec "$$@"
        CODE_WRAPPER: |
          #!/bin/bash

          # FIFO-based host signaling
          ARGS=()
          WAIT=0
          for arg in "$$@"; do
            if [[ "$$arg" == "-w" || "$$arg" == "--wait" ]]; then
              WAIT=1
              ARGS+=("$$arg")
            elif [[ "$$arg" == -* ]]; then
              ARGS+=("$$arg")
            else
              ARGS+=("$$(realpath "$$arg")")
            fi
          done
          echo "$${ARGS[*]}" > /tmp/vscode_fifo
          # Only wait for host response if -w/--wait was passed
          if [[ "$$WAIT" -eq 1 ]]; then
            read -r < /tmp/vscode_fifo_resp
          fi
        ON_BUILD: "${ON_BUILD:-}"
      dockerfile_inline: |
        FROM archlinux:latest

        # Install minimal dependencies
        RUN pacman -Syu --noconfirm \
          base-devel git sudo docker openssh nodejs npm

        # Create a non-root user and make it sudoer without password
        ENV USER=dev
        ARG UID=1000
        ARG GID=1000
        RUN groupadd -g $$GID $$USER \
          && useradd -mG wheel -g $$USER -s /bin/bash -u $$UID $$USER \
          && echo "$$USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/$$USER

        # Switch to the non-root user
        USER $$USER
        WORKDIR /tmp

        # Premake some directories to avoid permission issues
        RUN mkdir -p \
          /home/$$USER/.local/bin \
          /home/$$USER/.local/state/claude \
          /home/$$USER/.claude

        # Install yay (AUR helper) as the non-root user
        RUN git clone https://aur.archlinux.org/yay.git \
          && cd yay \
          && makepkg -si --noconfirm \
          && cd .. \
          && rm -rf yay

        # Install Claude Code
        RUN curl -fsSL https://claude.ai/install.sh | bash
        ENV PATH="/home/$$USER/.local/bin:$$PATH"

        # --- Project-specific layers (cheap, change per project) ---

        # Create a 'code' wrapper that signals the host to open VS Code
        ARG CODE_WRAPPER
        RUN echo "$$CODE_WRAPPER" > /home/$$USER/.local/bin/code \
          && chmod +x /home/$$USER/.local/bin/code

        # Create entrypoint script
        ARG ENTRYPOINT
        RUN echo "$$ENTRYPOINT" | sudo tee /entrypoint.sh > /dev/null \
          && sudo chmod +x /entrypoint.sh
        ENTRYPOINT ["/entrypoint.sh"]

        # Set the working directory
        ARG PROJECT_NAME
        RUN sudo mkdir -p /$$PROJECT_NAME/workspace \
          && sudo chown $$USER:$$USER /$$PROJECT_NAME/workspace
        WORKDIR /$$PROJECT_NAME/workspace

        # Run the ON_BUILD script if provided (used to pre-install tools)
        ARG ON_BUILD
        RUN if [ -n "$$ON_BUILD" ]; then \
          echo "$$ON_BUILD" | bash; \
        fi

        # Initial command to just keep the container running
        CMD ["bash", "-c", "sleep infinity"]
    environment:
      - GPG_PUBKEYS=${GPG_PUBKEYS:-}
    volumes:
      - ${TARGET_DIR}:/${PROJECT_NAME}/workspace
      - /var/run/docker.sock:/var/run/docker.sock
      - ${SSH_AUTH_SOCK:-/dev/null}:/tmp/ssh_auth_sock
      - ${GNUPG_SOCK:-/dev/null}:/tmp/gnupg_sock
      - ${GITCONFIG:-/dev/null}:/tmp/host_gitconfig
      - ${CLAUDE_JSON:-/dev/null}:/tmp/host_claude_json
      - ${CLAUDE_HOME:-claude_home}:/home/dev/.claude
      - ${CLAUDE_STATE:-claude_state}:/home/dev/.local/state/claude
      - ${VSCODE_FIFO:-/dev/null}:/tmp/vscode_fifo
      - ${VSCODE_FIFO_RESP:-/dev/null}:/tmp/vscode_fifo_resp
      - ${VIBE_DIR}:/${PROJECT_NAME}/workspace/.vibe

volumes:
  claude_home:
  claude_state:
EOF
)"

# Utility function to run docker compose with the correct arguments
compose() {
  GID=$(id -g) docker compose --project-name "$PROJECT_NAME" "$@"
}

get_container_id() {
  docker ps --filter "name=${PROJECT_NAME}-claude-1" -q
}

# Tear down the compose file and exit if requested
if ((DOWN)); then
  compose down
  # Clean up the VS Code FIFOs
  VSCODE_FIFO="/tmp/vibe-vscode-${PROJECT_NAME}.fifo"
  VSCODE_FIFO_RESP="/tmp/vibe-vscode-${PROJECT_NAME}-resp.fifo"
  rm -f "$VSCODE_FIFO" "$VSCODE_FIFO_RESP"
  exit 0
fi

# Setup the GPG extra socket.
# The extra socket is more restricted then the normal socket
GNUPG_SOCK=$(gpgconf --list-dir agent-extra-socket)
if [[ -S "$GNUPG_SOCK" ]]; then
  export GNUPG_SOCK
  GPG_PUBKEYS=$(gpg --export -a 2>/dev/null)
  export GPG_PUBKEYS
fi

# Setup gitconfig if it exists
if [[ -f "$HOME/.gitconfig" ]]; then
  export GITCONFIG="$HOME/.gitconfig"
fi

# Setup the VS Code FIFOs if 'code' is available on the host
HAS_CODE=0
if command -v code &>/dev/null; then
  HAS_CODE=1
  VSCODE_FIFO="/tmp/vibe-vscode-${PROJECT_NAME}.fifo"
  VSCODE_FIFO_RESP="/tmp/vibe-vscode-${PROJECT_NAME}-resp.fifo"
  for fifo in "$VSCODE_FIFO" "$VSCODE_FIFO_RESP"; do
    if [[ ! -p "$fifo" ]]; then
      mkfifo "$fifo"
      chmod 666 "$fifo"
    fi
  done
  export VSCODE_FIFO VSCODE_FIFO_RESP
fi

# Check if the user has an on_build.sh script in ~/.vibe
ON_BUILD_SCRIPT="$HOME/.claude-docker/on_build.sh"
if [[ -f "$ON_BUILD_SCRIPT" ]]; then
  ON_BUILD="$(cat "$ON_BUILD_SCRIPT")"
  export ON_BUILD
fi

# Setup host config directories (default) or use local Docker volumes (-l flag)
if ! ((LOCAL)); then
  export CLAUDE_STATE="${HOME}/.local/state/claude"
  export CLAUDE_HOME="${HOME}/.claude"

  mkdir -p "$CLAUDE_STATE" "$CLAUDE_HOME"

  # Ensure the file exists with valid JSON so Docker can mount it as a file
  export CLAUDE_JSON="${HOME}/.claude.json"
  if [[ ! -f "$CLAUDE_JSON" ]]; then
    echo '{}' > "$CLAUDE_JSON"
  fi
fi

UP_ARGS=()
if ((BUILD)); then
  UP_ARGS+=("--build")
fi
compose --file - up "${UP_ARGS[@]}" -d <<< "$DOCKER_COMPOSE"

# Helper to open VS Code attached to the container
open_vscode() {
  local container_id path hex_id
  container_id="$(get_container_id)"
  path="${1:-/$PROJECT_NAME/workspace}"
  hex_id="$(printf '%s' "$container_id" | od -A n -t x1 | tr -d ' \n')"
  code --folder-uri "vscode-remote://attached-container+${hex_id}${path}"
}

# Start background watcher and VS Code integration if 'code' is available
WATCHER_PID=""
if ((HAS_CODE)); then
  (
    echo "Launching code watcher socket"
    while true; do
      if read -r args < "$VSCODE_FIFO"; then
        container_id="$(get_container_id)"
        hex_id="$(printf '%s' "$container_id" | od -A n -t x1 | tr -d ' \n')"
        uri_base="vscode-remote://attached-container+${hex_id}"

        # Separate flags from paths
        flags=()
        paths=()
        # shellcheck disable=SC2086
        for arg in $args; do
          if [[ "$arg" == -* ]]; then
            flags+=("$arg")
          else
            paths+=("$arg")
          fi
        done

        # Build code command with correct URI type for each path
        code_args=("${flags[@]}")
        has_folder=0
        for path in "${paths[@]}"; do
          if docker exec "$container_id" test -d "$path" 2>/dev/null; then
            has_folder=1
            code_args+=("--folder-uri" "${uri_base}${path}")
          else
            code_args+=("--file-uri" "${uri_base}${path}")
          fi
        done

        # Always attach to /workspace unless a directory was explicitly given
        if [[ "$has_folder" -eq 0 ]]; then
          code_args+=("--folder-uri" "${uri_base}/$PROJECT_NAME/workspace")
        fi

        code "${code_args[@]}"
        # Only signal response if -w/--wait was requested
        if [[ " ${flags[*]} " == *" -w "* || " ${flags[*]} " == *" --wait "* ]]; then
          echo "done" > "$VSCODE_FIFO_RESP"
        fi
      fi
    done
  ) &
  WATCHER_PID=$!
fi

# Clean up watcher on exit
cleanup() {
  if [[ -n "$WATCHER_PID" ]]; then
    kill "$WATCHER_PID" 2>/dev/null || true
  fi
  if ! ((KEEP)); then
    compose down
    rm -f "/tmp/vibe-vscode-${PROJECT_NAME}.fifo" "/tmp/vibe-vscode-${PROJECT_NAME}-resp.fifo"
  fi
}
trap cleanup EXIT

# Open VS Code if requested via -v flag
if ((VSCODE)); then
  if ! ((HAS_CODE)); then
    echo "Error: 'code' command not found on host" >&2
    exit 1
  fi
  open_vscode "/$PROJECT_NAME/workspace"
fi

# Helper for compose exec with explicit working directory
EXEC=(compose exec -w "/${PROJECT_NAME}/workspace" claude)

# Shell into the container if in debug mode
if ((DEBUG)); then
  "${EXEC[@]}" /entrypoint.sh bash
  exit 0
fi

# Run Claude Code in the container
SYSTEM_PROMPT="
Disposable Docker container with passwordless sudo — install anything freely.
After installing a tool, append its directory to ~/.bin-paths.
At session start, run: export PATH=\"\$(cat ~/.bin-paths 2>/dev/null | tr '\\n' ':'):\$PATH\"

Check .vibe/ for context files (PLAN.md, PROGRESS.md, etc.) and keep them updated. Max 150 lines each.

Be concise. Prefer simple, clean solutions over hacky or overengineered ones.
When unsure, ask the user. If the implementation diverges significantly from the plan,
stop and consult the user before proceeding.
Break large plans into small steps — each step should fit in one reviewable commit.
Complete one step at a time, then ask before moving to the next.
"

TOOL_FLAGS=(--dangerously-skip-permissions --append-system-prompt "$SYSTEM_PROMPT")

echo "Running 'claude' in container..."
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
  "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}" "${EXTRA_ARGS[@]}"
else
  CLAUDE_PROJECT_DIR="/home/dev/.claude/projects/-${PROJECT_NAME}-workspace"
  : "$(
    compose exec -T -w "/${PROJECT_NAME}/workspace" claude \
    bash -c 'ls -t '"${CLAUDE_PROJECT_DIR}"'/*.jsonl 2>/dev/null' \
    | head -1 | xargs -r basename
  )"
  SESSION_ID="${_%.*}" # Strip .jsonl suffix

  if [[ -n "$SESSION_ID" ]]; then
    echo "Resuming session $SESSION_ID"
    "${EXEC[@]}" /entrypoint.sh claude --resume "$SESSION_ID" "${TOOL_FLAGS[@]}"
  else
    "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}"
  fi
fi

# Prompt to remove worktree if one was created
if [[ -n "$WORKTREE" ]]; then
  read -rp "Remove worktree '$WORKTREE_BRANCH'? [y/N] " answer
  if [[ "$answer" == [yY] ]]; then
    git worktree remove "$WORKTREE"
    echo "Worktree '$WORKTREE_BRANCH' removed."
  fi
fi
